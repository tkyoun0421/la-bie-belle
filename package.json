{
  "name": "la-bie-belle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts tests eslint.config.mjs next.config.ts postcss.config.mjs prettier.config.mjs tailwind.config.ts vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "node scripts/db-status.mjs",
    "db:reset": "supabase db reset",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "supabase": "^2.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,md,css}": ["prettier --write"]
  }
}
