{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Harness Improvement Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "source",
    "target_area",
    "problem",
    "proposal",
    "expected_impact",
    "risk",
    "status",
    "created_at"
  ],
  "properties": {
    "proposal_id": { "type": "string" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id"],
      "properties": {
        "run_id": { "type": "string" },
        "issue_number": { "type": ["integer", "null"] },
        "harness_health_score_id": { "type": ["string", "null"] }
      }
    },
    "target_area": {
      "type": "string",
      "enum": [
        "task_spec",
        "context_injection",
        "role_handoff",
        "verification_gate",
        "scoring_rubric",
        "record_dashboard",
        "other"
      ]
    },
    "problem": { "type": "string" },
    "proposal": { "type": "string" },
    "expected_impact": { "type": "string" },
    "risk": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "implemented"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "decided_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
