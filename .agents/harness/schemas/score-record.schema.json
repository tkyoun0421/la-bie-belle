{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI 하네스 점수 기록",
  "type": "object",
  "required": ["score_id", "rubric", "total_score", "decision", "categories"],
  "properties": {
    "score_id": { "type": "string" },
    "rubric": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer" }
      }
    },
    "total_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "decision": {
      "type": "string",
      "enum": ["PASS", "REWORK", "FAIL", "INFO"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "score", "max_score", "evidence", "deductions"],
        "properties": {
          "id": { "type": "string" },
          "score": { "type": "number" },
          "max_score": { "type": "number" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deductions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weaknesses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_action": { "type": "string" },
    "scored_at": { "type": "string", "format": "date-time" }
  }
}
